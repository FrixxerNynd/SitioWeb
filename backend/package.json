  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-mssql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.16.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "redis": "^6.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "morgan": "^1.10.1",
    "prisma": "^7.8.0",
