model sysdiagrams {
  name         String @db.NVarChar(128)
  principal_id Int
  diagram_id   Int    @id(map: "PK__sysdiagr__C2B05B617CD819D2") @default(autoincrement())
  version      Int?
  definition   Bytes?

  @@unique([principal_id, name], map: "UK_principal_name")
}

model usuario_horarios {
  Id            Int       @id(map: "PK__usuario___3214EC074B19A7AF") @default(autoincrement())
  UsuarioId     Int
  Nombre        String    @db.NVarChar(100)
  DiaInicio     String    @db.NVarChar(20)
  DiaFin        String    @db.NVarChar(20)
  HoraInicio    DateTime  @db.Time
  HoraFin       DateTime  @db.Time
  IsCompartido  Boolean   @default(false, map: "DF__usuario_h__IsCom__0B91BA14")
  CreadoEn      DateTime  @default(dbgenerated("getutcdate()"), map: "DF__usuario_h__Cread__0C85DE4D")
  ActualizadoEn DateTime?
  auth_usuarios User      @relation(fields: [UsuarioId], references: [id], onDelete: Cascade, map: "FK_usuario_horarios_auth_usuarios")
}

model Cart {
  id             Int        @id @default(autoincrement())
  userId         Int        @unique
  paymentType    String     @default("Transferencia") @db.VarChar(50)
  deliveryMethod String?    @db.VarChar(50)
  shippingCost   Float      @default(0)
  frozenAddress  String?    @db.NVarChar(Max)
  subtotal       Float      @default(0)
  total          Float      @default(0)
  createdAt      DateTime   @default(now())
  items          CartItem[]
}

model CartItem {
  id         Int    @id @default(autoincrement())
  cartId     Int
  productId  Int
  sku        String @db.VarChar(100)
  name       String @db.NVarChar(200)
  price      Float
  quantity   Int
  totalPrice Float
  cart       Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int
  paymentType     String      @db.VarChar(50)
  deliveryMethod  String      @db.VarChar(50)
  shippingCost    Float       @default(0)
  shippingAddress String?     @db.NVarChar(Max)
  subtotal        Float
  total           Float
  status          String      @db.VarChar(50)
  createdAt       DateTime    @default(now())
  items           OrderItem[]
}

model OrderItem {
  id         Int    @id @default(autoincrement())
  orderId    Int
  productId  Int
  sku        String @db.VarChar(100)
  name       String @db.NVarChar(200)
  price      Float
  quantity   Int
  totalPrice Float
  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model UserAddress {
  id           Int     @id @default(autoincrement())
  userId       Int
  street       String  @db.NVarChar(200)
  extNum       String  @db.VarChar(20)
  intNum       String? @db.VarChar(20)
  neighborhood String  @db.NVarChar(100)
  city         String  @db.NVarChar(100)
  state        String  @db.NVarChar(100)
  cp           String  @db.VarChar(10)
  country      String  @db.NVarChar(100)
}


